# Dependency directories
**/node_modules/
**/jspm_packages/

# Next.js build output
**/.next/
**/out/

# Environment files (sensitive info)
**/.env
**/.env.*
!**/.env.example

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Java / Maven build output
**/target/
**/*.class
**/*.log

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS metadata
.DS_Store
Thumbs.db

# Ignore all markdown files globally
**/*.md
**/*.MD

# EXCEPT README.md files (case-insensitive)
!**/README.md
!**/README.MD
!**/readme.md
!**/readme.MD
